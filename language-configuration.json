{
    "comments": {
        "lineComment": "//",
        "blockComment": null
    },
    "brackets": [
        [
            "{",
            "}"
        ],
        [
            "(",
            ")"
        ],
        [
            "[",
            "]"
        ]
    ],
    "autoClosingPairs": [
        {
            "open": "{",
            "close": "}"
        },
        {
            "open": "(",
            "close": ")"
        },
        {
            "open": "[",
            "close": "]"
        },
        {
            "open": "\"",
            "close": "\"",
            "notIn": [
                "string"
            ]
        },
    ],
    "surroundingPairs": [
        [
            "{",
            "}"
        ],
        [
            "(",
            ")"
        ],
        [
            "[",
            "]"
        ],
        [
            "\"",
            "\""
        ],
    ],
    "folding": {
        "markers": {
            "start": "\\{\\s*$",
            "end": "^\\s*\\}"
        }
    },
    "indentationRules": {
        "increaseIndentPattern": "\\{[^}]*$",
        "decreaseIndentPattern": "^\\s*\\}"
    },
    "wordPattern": "[$@#]?[a-zA-Z_][a-zA-Z0-9_]*"
}
